DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lastmile?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
APP_URL="http://localhost:3000"
CRON_SECRET="replace-with-a-separate-random-secret"

# Domain-free email option: verify a personal sender address in Brevo.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Dispatch"

# Optional custom-domain email provider.
RESEND_API_KEY=""
EMAIL_FROM="Dispatch <notifications@example.com>"

# SMS provider. Twilio trial accounts can message verified test numbers.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
